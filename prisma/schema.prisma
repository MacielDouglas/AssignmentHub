generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  USER
  SUPER_ADMIN
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum Sex {
  MALE
  FEMALE
}

enum CleaningType {
  MEETING
  WEEKLY
  GENERAL
}

enum CleaningAssignmentMode {
  GROUP
  FAMILY
  PERSON
}

enum CleaningAssignmentListStatus {
  DRAFT
  SAVED
}

enum CleaningSectorTargetSex {
  MALE
  FEMALE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OrganizationScheduleType {
  MEETINGS
  SPECIAL_MEETING
  TRAVELING_OVERSEER_VISIT
  CELEBRATION
  SPECIAL_TALK
  CIRCUIT_ASSEMBLY_TRAVELING_OVERSEER
  CIRCUIT_ASSEMBLY_BRANCH_REPRESENTATIVE
  FIELD_SERVICE_MEETING
  CONVENTION
  WEEKLY_CLEANING
  GENERAL_CLEANING
}

enum OrganizationScheduleMode {
  WEEKLY_RECURRING
  SINGLE_DATETIME
  MULTIPLE_DATES
  DATE_RANGE
  MULTIPLE_DATETIME
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean
  image         String?
  systemRole    SystemRole @default(USER)
  personId      String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  person      Person?                  @relation(fields: [personId], references: [id], onDelete: Restrict)
  sessions    Session[]
  accounts    Account[]
  memberships OrganizationMembership[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      OrganizationMembership[]
  people           Person[]
  families         Family[]
  groups           Group[]
  subOrganizations SubOrganization[]
  cleaningSettings OrganizationCleaningSettings?
  schedules        OrganizationSchedule[]
  cleaningLists    CleaningAssignmentList[]

  @@index([slug])
}

model OrganizationMembership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String           @unique
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
  @@index([userId])
}

model Outline {
  id        String   @id @default(uuid())
  number    Int      @unique
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subPeople SubPerson[]
  person    Person[]
}

model SubOrganization {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people       SubPerson[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model SubPerson {
  id                String   @id @default(uuid())
  subOrganizationId String
  name              String
  sex               Sex      @default(MALE)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subOrganization SubOrganization @relation(fields: [subOrganizationId], references: [id], onDelete: Cascade)
  outlines        Outline[]

  @@index([subOrganizationId, name])
}

model Family {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  headId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization                         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  head                Person                               @relation("FamilyHead", fields: [headId], references: [id], onDelete: Restrict)
  members             Person[]                             @relation("FamilyMembers")
  cleaningTypeConfigs CleaningTypeConfig[]                 @relation("CleaningConfigFamily")
  cleaningAssignments CleaningAssignmentSectorAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([headId])
}

model Group {
  id               String   @id @default(uuid())
  organizationId   String
  name             String
  slug             String
  superintendentId String
  assistantId      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization        Organization                         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  superintendent      Person                               @relation("GroupSuperintendent", fields: [superintendentId], references: [id], onDelete: Restrict)
  assistant           Person                               @relation("GroupAssistant", fields: [assistantId], references: [id], onDelete: Restrict)
  members             Person[]                             @relation("GroupMembers")
  cleaningTypeConfigs CleaningTypeConfig[]                 @relation("CleaningConfigGroup")
  cleaningAssignments CleaningAssignmentSectorAssignment[]

  @@unique([organizationId, name])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, slug])
  @@index([superintendentId])
  @@index([assistantId])
}

model Person {
  id             String  @id @default(uuid())
  organizationId String?
  familyId       String?
  groupId        String?
  spouseId       String? @unique
  name           String
  sex            Sex     @default(MALE)
  isActive       Boolean @default(true)
  isStudent      Boolean @default(true)
  isMarried      Boolean @default(false)

  baptized                Boolean @default(false)
  young                   Boolean @default(true)
  initiatingConversations Boolean @default(false)
  cultivatingInterest     Boolean @default(false)
  makingDisciples         Boolean @default(false)
  explainingBeliefs       Boolean @default(false)
  cleaning                Boolean @default(true)
  privilegePrayer         Boolean @default(false)

  bibleReading     Boolean @default(false)
  roamingMic       Boolean @default(false)
  sound            Boolean @default(false)
  video            Boolean @default(false)
  stage            Boolean @default(false)
  bibleStudyReader Boolean @default(false)
  watchtowerReader Boolean @default(false)
  attendant        Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  outlines  Outline[]

  organization           Organization?                        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family                 Family?                              @relation("FamilyMembers", fields: [familyId], references: [id], onDelete: SetNull)
  headedFamily           Family?                              @relation("FamilyHead")
  user                   User?
  servicePrivilege       ServicePrivilege?
  group                  Group?                               @relation("GroupMembers", fields: [groupId], references: [id], onDelete: SetNull)
  superintendentOfGroups Group[]                              @relation("GroupSuperintendent")
  assistantOfGroups      Group[]                              @relation("GroupAssistant")
  cleaningTypeConfigs    CleaningTypeConfig[]                 @relation("CleaningConfigPerson")
  scheduleOccurrences    OrganizationScheduleOccurrence[]     @relation("ScheduleLeaderPerson")
  cleaningAssignments    CleaningAssignmentSectorAssignment[]

  spouse    Person? @relation("PersonSpouse", fields: [spouseId], references: [id], onDelete: SetNull)
  marriedTo Person? @relation("PersonSpouse")

  @@index([organizationId, name])
  @@index([familyId])
  @@index([groupId])
  @@index([organizationId, familyId])
  @@index([organizationId, groupId])
  @@index([spouseId])
}

model ServicePrivilege {
  id                         String  @id @default(uuid())
  personId                   String  @unique
  elder                      Boolean @default(false)
  publicTalk                 Boolean @default(false)
  spiritualGems              Boolean @default(false)
  treasuresFromGodsWordTalk  Boolean @default(false)
  lifeAndMinistryChairman    Boolean @default(false)
  weekendChairman            Boolean @default(false)
  ourChristianLifeAssignment Boolean @default(false)
  localNeeds                 Boolean @default(false)
  bibleStudyConductor        Boolean @default(false)
  watchtowerConductor        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model OrganizationCleaningSettings {
  id                 String   @id @default(uuid())
  organizationId     String   @unique
  cleaningPerMeeting Boolean  @default(false)
  weeklyCleaning     Boolean  @default(false)
  generalCleaning    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configs      CleaningTypeConfig[]

  @@index([organizationId])
}

model CleaningTypeConfig {
  id             String                  @id @default(uuid())
  settingsId     String
  type           CleaningType
  enabled        Boolean                 @default(false)
  assignmentMode CleaningAssignmentMode?
  notes          String?

  groupId  String?
  familyId String?
  personId String?

  timesPerWeek Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings OrganizationCleaningSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  sectors  CleaningSector[]
  weekdays CleaningWeekday[]
  dates    CleaningDate[]

  group  Group?  @relation("CleaningConfigGroup", fields: [groupId], references: [id], onDelete: SetNull)
  family Family? @relation("CleaningConfigFamily", fields: [familyId], references: [id], onDelete: SetNull)
  person Person? @relation("CleaningConfigPerson", fields: [personId], references: [id], onDelete: SetNull)

  @@unique([settingsId, type])
  @@index([settingsId, type])
  @@index([groupId])
  @@index([familyId])
  @@index([personId])
}

model CleaningWeekday {
  id                   String  @id @default(uuid())
  cleaningTypeConfigId String
  weekday              Weekday
  sortOrder            Int     @default(0)

  cleaningTypeConfig CleaningTypeConfig @relation(fields: [cleaningTypeConfigId], references: [id], onDelete: Cascade)

  @@unique([cleaningTypeConfigId, weekday])
  @@index([cleaningTypeConfigId, sortOrder])
}

model CleaningDate {
  id                   String   @id @default(uuid())
  cleaningTypeConfigId String
  date                 DateTime
  label                String?
  createdAt            DateTime @default(now())

  cleaningTypeConfig CleaningTypeConfig @relation(fields: [cleaningTypeConfigId], references: [id], onDelete: Cascade)

  @@index([cleaningTypeConfigId, date])
}

model CleaningSector {
  id                   String                   @id @default(uuid())
  cleaningTypeConfigId String
  name                 String
  description          String?
  peopleRequired       Int?
  allowYoung           Boolean                  @default(true)
  targetSex            CleaningSectorTargetSex?
  sortOrder            Int                      @default(0)
  isActive             Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  cleaningTypeConfig CleaningTypeConfig                   @relation(fields: [cleaningTypeConfigId], references: [id], onDelete: Cascade)
  assignments        CleaningAssignmentSectorAssignment[]

  @@index([cleaningTypeConfigId, sortOrder])
  @@index([cleaningTypeConfigId, isActive])
  @@index([cleaningTypeConfigId, targetSex])
}

model OrganizationSchedule {
  id             String                   @id @default(uuid())
  organizationId String
  type           OrganizationScheduleType
  mode           OrganizationScheduleMode
  title          String
  description    String?
  isActive       Boolean                  @default(true)
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  weeklyRules  OrganizationScheduleWeeklyRule[]
  occurrences  OrganizationScheduleOccurrence[]

  @@index([organizationId, type])
  @@index([organizationId, isActive])
  @@index([organizationId, effectiveFrom])
  @@index([organizationId, effectiveUntil])
  @@index([organizationId, type, effectiveFrom])
}

model OrganizationScheduleWeeklyRule {
  id                     String   @id @default(uuid())
  organizationScheduleId String
  weekday                Weekday
  time                   String
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organizationSchedule OrganizationSchedule @relation(fields: [organizationScheduleId], references: [id], onDelete: Cascade)

  @@unique([organizationScheduleId, weekday, time])
  @@index([organizationScheduleId, sortOrder])
}

model OrganizationScheduleOccurrence {
  id                     String    @id @default(uuid())
  organizationScheduleId String
  startDate              DateTime
  endDate                DateTime?
  time                   String?
  isAllDay               Boolean   @default(false)
  leaderPersonId         String?
  location               String?
  notes                  String?
  sortOrder              Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organizationSchedule OrganizationSchedule @relation(fields: [organizationScheduleId], references: [id], onDelete: Cascade)
  leaderPerson         Person?              @relation("ScheduleLeaderPerson", fields: [leaderPersonId], references: [id], onDelete: SetNull)

  @@index([organizationScheduleId, startDate])
  @@index([organizationScheduleId, endDate])
  @@index([leaderPersonId])
}

model CleaningAssignmentList {
  id             String                       @id @default(uuid())
  organizationId String
  cleaningType   CleaningType
  periodFrom     DateTime
  periodTo       DateTime
  status         CleaningAssignmentListStatus @default(DRAFT)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dates        CleaningAssignmentDate[]

  @@index([organizationId, cleaningType, periodFrom])
  @@index([organizationId, periodFrom, periodTo])
  @@index([organizationId, status, createdAt])
}

model CleaningAssignmentDate {
  id        String   @id @default(uuid())
  listId    String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list        CleaningAssignmentList               @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignments CleaningAssignmentSectorAssignment[]

  @@unique([listId, date])
  @@index([listId, date])
  @@index([date])
}

model CleaningAssignmentSectorAssignment {
  id               String   @id @default(uuid())
  assignmentDateId String
  sectorId         String
  personId         String
  familyId         String?
  groupId          String?
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignmentDate CleaningAssignmentDate @relation(fields: [assignmentDateId], references: [id], onDelete: Cascade)
  sector         CleaningSector         @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  person         Person                 @relation(fields: [personId], references: [id], onDelete: Restrict)
  family         Family?                @relation(fields: [familyId], references: [id], onDelete: SetNull)
  group          Group?                 @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([assignmentDateId, sectorId])
  @@index([personId])
  @@index([familyId])
  @@index([groupId])
  @@index([sectorId, position])
}
